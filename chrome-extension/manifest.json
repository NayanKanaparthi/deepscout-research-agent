{
  "manifest_version": 3,
  "name": "Deepscout",
  "version": "1.1.0",
  "description": "Deepscout — AI-powered deep research with search, reasoning, and citations",
  "permissions": [
    "sidePanel",
    "activeTab",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:8001/*",
    "https://html.duckduckgo.com/*",
    "https://duckduckgo.com/*",
    "<all_urls>"
  ],
  "side_panel": {
    "default_path": "sidepanel.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Open Deepscout"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
